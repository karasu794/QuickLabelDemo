--
-- Name: shipments Admin users have full access to shipments.; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admin users have full access to shipments." ON public.shipments USING ((EXISTS ( SELECT 1
   FROM public.profiles
  WHERE ((profiles.id = auth.uid()) AND (profiles.role = 'admin'::text))))) WITH CHECK ((EXISTS ( SELECT 1
   FROM public.profiles
  WHERE ((profiles.id = auth.uid()) AND (profiles.role = 'admin'::text)))));


--
-- Name: POLICY "Admin users have full access to shipments." ON shipments; Type: COMMENT; Schema: public; Owner: postgres
--

COMMENT ON POLICY "Admin users have full access to shipments." ON public.shipments IS '管理者ユーザーは全ての送り状にアクセス可能';


