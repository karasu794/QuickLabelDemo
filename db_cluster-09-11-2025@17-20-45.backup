SET default_tablespace = '';

SET default_table_access_method = heap;

--
-- Name: jobs; Type: TABLE; Schema: public; Owner: postgres
--

CREATE TABLE public.jobs (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    type text NOT NULL,
    status text NOT NULL,
    attempts integer DEFAULT 0 NOT NULL,
    locked boolean DEFAULT false NOT NULL,
    next_run_at timestamp with time zone,
    status_detail text,
    last_error_code text,
    last_error text,
    idempotency_key text,
    payload jsonb DEFAULT '{}'::jsonb NOT NULL,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT jobs_status_check CHECK ((status = ANY (ARRAY['queued'::text, 'running'::text, 'succeeded'::text, 'failed'::text])))
);


ALTER TABLE public.jobs OWNER TO postgres;

--
-- Name: jobs_pick_for_update(text, timestamp with time zone); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.jobs_pick_for_update(p_type text, p_now timestamp with time zone) RETURNS public.jobs
    LANGUAGE sql SECURITY DEFINER
    AS $$
  with cte as (
    select id
    from public.jobs
    where type = p_type
      and status = 'queued'
      and locked = false
      and (next_run_at is null or next_run_at <= p_now)
    order by next_run_at nulls first, created_at
    limit 1
    for update skip locked
  )
  update public.jobs j
    set status = 'running',
        locked = true,
        attempts = j.attempts + 1,
        updated_at = now()
  from cte
  where j.id = cte.id
  returning j.*;
$$;


ALTER FUNCTION public.jobs_pick_for_update(p_type text, p_now timestamp with time zone) OWNER TO postgres;

