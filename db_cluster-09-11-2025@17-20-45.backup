-- Name: cleanup_old_exchange_rates(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.cleanup_old_exchange_rates() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- 新しいレコードが挿入された際に、同じ通貨ペアの古いレコードを削除
  DELETE FROM exchange_rates 
  WHERE currency_pair = NEW.currency_pair 
    AND id != NEW.id;
  
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.cleanup_old_exchange_rates() OWNER TO postgres;

--
-- Name: find_hs_codes_by_keywords(text[], integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.find_hs_codes_by_keywords(input_keywords text[], limit_count integer DEFAULT 10) RETURNS TABLE(id uuid, code character varying, description_jp text, description_en text, match_count integer)
    LANGUAGE sql STABLE
    AS $$
    SELECT 
        hc.id,
        hc.code,
        hc.description_jp,
        hc.description_en,
        (
            SELECT COUNT(*)
            FROM unnest(input_keywords) AS input_kw
            WHERE hc.keywords @> to_jsonb(ARRAY[lower(input_kw)])
        )::INTEGER AS match_count
    FROM public.hs_codes hc
    WHERE hc.is_active = true
    AND EXISTS (
        SELECT 1
        FROM unnest(input_keywords) AS input_kw
        WHERE hc.keywords @> to_jsonb(ARRAY[lower(input_kw)])
    )
    ORDER BY match_count DESC, hc.code
    LIMIT limit_count;
$$;


ALTER FUNCTION public.find_hs_codes_by_keywords(input_keywords text[], limit_count integer) OWNER TO postgres;

