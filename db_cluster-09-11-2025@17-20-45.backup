--
-- Name: search_hs_codes(text, text, integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.search_hs_codes(search_term text DEFAULT ''::text, search_lang text DEFAULT 'jp'::text, limit_count integer DEFAULT 20) RETURNS TABLE(id uuid, code character varying, description_jp text, description_en text, keywords jsonb, relevance_score real)
    LANGUAGE sql STABLE
    AS $$
    SELECT 
        hc.id,
        hc.code,
        hc.description_jp,
        hc.description_en,
        hc.keywords,
        CASE 
            WHEN search_lang = 'en' THEN
                ts_rank(to_tsvector('english', hc.description_en), plainto_tsquery('english', search_term))
            WHEN search_lang = 'jp' THEN
                CASE 
                    WHEN hc.description_jp ILIKE '%' || search_term || '%' THEN 1.0
                    WHEN hc.code ILIKE '%' || search_term || '%' THEN 0.8
                    ELSE 0.0
                END
            ELSE
                0.5
        END AS relevance_score
    FROM public.hs_codes hc
    WHERE hc.is_active = true
    AND (
        search_term = '' OR
        hc.code ILIKE '%' || search_term || '%' OR
        (search_lang = 'en' AND to_tsvector('english', hc.description_en) @@ plainto_tsquery('english', search_term)) OR
        (search_lang = 'jp' AND hc.description_jp ILIKE '%' || search_term || '%') OR
        hc.keywords @> to_jsonb(ARRAY[lower(search_term)])
    )
    ORDER BY relevance_score DESC, hc.code
    LIMIT limit_count;
$$;


ALTER FUNCTION public.search_hs_codes(search_term text, search_lang text, limit_count integer) OWNER TO postgres;

--
-- Name: suggest_hs_codes_for_description(text, integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.suggest_hs_codes_for_description(product_description text, limit_count integer DEFAULT 5) RETURNS TABLE(id uuid, code character varying, description_jp text, description_en text, confidence_score real)
    LANGUAGE sql STABLE
    AS $$
    WITH matched_keywords AS (
        SELECT 
            hc.id,
            hc.code,
            hc.description_jp,
            hc.description_en,
            (
                SELECT COUNT(*)
                FROM jsonb_array_elements_text(hc.keywords) AS keyword
                WHERE lower(product_description) LIKE '%' || keyword || '%'
            ) AS keyword_matches,
            CASE 
                WHEN hc.description_jp ILIKE '%' || product_description || '%' THEN 1.0
                WHEN hc.description_en ILIKE '%' || product_description || '%' THEN 0.9
                WHEN hc.code ILIKE '%' || product_description || '%' THEN 0.7
                ELSE 0.0
            END AS text_similarity
        FROM public.hs_codes hc
        WHERE hc.is_active = true
    )
    SELECT 
        mk.id,
        mk.code,
        mk.description_jp,
        mk.description_en,
        (mk.keyword_matches * 0.7 + mk.text_similarity * 0.3) AS confidence_score
    FROM matched_keywords mk
    WHERE mk.keyword_matches > 0 OR mk.text_similarity > 0.0
    ORDER BY confidence_score DESC, mk.code
    LIMIT limit_count;
$$;


ALTER FUNCTION public.suggest_hs_codes_for_description(product_description text, limit_count integer) OWNER TO postgres;

