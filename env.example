# QuickLabel Environment Variables Example
# Copy this file to .env.local and update with your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PDF Generation (Optional)
# If you have issues with PDF generation, set this to your Chrome executable path
# CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# For debugging PDF generation
# PDF_DEBUG=true

# Square Payment (if using)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ACCESS_TOKEN=your_square_access_token

# FedEx API (if using)
FEDEX_API_KEY=your_fedex_api_key
FEDEX_SECRET_KEY=your_fedex_secret_key
