# QuickLabel Environment Variables Example
# Copy this file to .env.local and update with your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PDF Generation (Optional)
# If you have issues with PDF generation, set this to your Chrome executable path
# CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# For debugging PDF generation
# PDF_DEBUG=true

# Square Payment (if using)
# Client-side (public): 必須
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id

# Server-side (optional):
# SQUARE_APPLICATION_ID=your_square_app_id  # server only（任意）/ mirror to NEXT_PUBLIC_SQUARE_APP_ID
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id

# FedEx API (if using)
# Use export/import creds for production
FEDEX_EXPORT_API_KEY=your_fedex_export_api_key
FEDEX_EXPORT_SECRET_KEY=your_fedex_export_secret_key
FEDEX_EXPORT_ACCOUNT_NUMBER=your_fedex_export_account
FEDEX_IMPORT_API_KEY=your_fedex_import_api_key
FEDEX_IMPORT_SECRET_KEY=your_fedex_import_secret_key
FEDEX_IMPORT_ACCOUNT_NUMBER=your_fedex_import_account
# FEDEX_API_BASE_URL=https://apis.fedex.com



# Blob (Vercel Blob)
# BLOB_READ_WRITE_TOKEN=...

# Production-only Ship safety flags (server-only)
SHIP_API_WRITE_ENABLED=false
REQUIRE_RATE_MATCH=true
# RateGuard (new unified names)
RATE_GUARD_MAX_ABS=300
RATE_GUARD_MAX_PCT=0.02
# Back-compat (fallback read only; will be removed)
# RATE_MATCH_YEN_TOLERANCE=300
# RATE_MATCH_PERCENT_TOLERANCE=2

# Stage3 (admin toggle is persisted in DB app_settings; these ENV are defaults only)
# FORCE_PHOENIX_LETTERHEAD=true
# FORCE_PHOENIX_SIGNATURE=true

# Public Quotes org (for anonymous quotes)
PUBLIC_QUOTES_ORG_ID=ca5f9ace-4206-4419-a9fe-3becd1c1f167

# Comma-separated admin emails for override (optional)
ADMIN_EMAILS=

PUBLIC_QUOTES_ORG_ID=ca5f9ace-4206-4419-a9fe-3becd1c1f167

# Feature flags for phased signin refit
NEXT_PUBLIC_ENABLE_NEW_LOGIN=false
NEXT_PUBLIC_ENABLE_AUTHGUARD_REDIRECT=false

# HTS Suggestions (UI only toggle; default OFF)
# When 'true', UI may show suggestion trigger; API call may still be disabled.
FEATURE_HTS_SUGGESTIONS=false
NEXT_PUBLIC_FEATURE_HTS_SUGGESTIONS=false