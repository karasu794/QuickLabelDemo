# ============================================================
# FQL デモ環境 — Vercel 環境変数テンプレート
# ============================================================
# Vercel Dashboard > Settings > Environment Variables に設定する。
# NEXT_PUBLIC_ prefix の変数は Preview/Production 両方に設定すること。
# ============================================================

# ==== デモモード制御（必須） ====
APP_ENV=demo
NEXT_PUBLIC_APP_ENV=demo
SHIP_API_WRITE_ENABLED=false
CORE_MODE=true

# ==== FedEx (Sandbox) ====
FEDEX_ENV=sandbox
FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
NEXT_PUBLIC_FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_EXPORT_API_KEY=<your-sandbox-key>
FEDEX_EXPORT_SECRET_KEY=<your-sandbox-secret>
FEDEX_EXPORT_ACCOUNT_NUMBER=<your-sandbox-account>
FEDEX_IMPORT_API_KEY=<your-sandbox-key>
FEDEX_IMPORT_SECRET_KEY=<your-sandbox-secret>
FEDEX_IMPORT_ACCOUNT_NUMBER=<your-sandbox-account>
FEDEX_CLIENT_ID=<your-sandbox-key>
FEDEX_CLIENT_SECRET=<your-sandbox-secret>

# ==== Square (Sandbox) ====
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=<your-sandbox-token>
SQUARE_APPLICATION_ID=<your-sandbox-app-id>
SQUARE_LOCATION_ID=<your-sandbox-location>
QL_ENABLE_SQUARE_CANCEL=false
NEXT_PUBLIC_SQUARE_APP_ID=<your-sandbox-app-id>
NEXT_PUBLIC_SQUARE_LOCATION_ID=<your-sandbox-location>

# ==== Supabase ====
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_JWT_SECRET=<your-jwt-secret>
SUPABASE_PROJECT_REF=<your-project-ref>
SUPABASE_URL=<your-supabase-url>

# ==== Google Maps ====
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-google-maps-key>

# ==== ExchangeRate API ====
EXCHANGERATE_API_KEY=<your-exchangerate-key>

# ==== Storage / Caching ====
BLOB_READ_WRITE_TOKEN=<your-vercel-blob-token>
UPSTASH_REDIS_REST_URL=<your-upstash-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# ==== App URLs（Vercelデプロイ後に実URLに差し替え） ====
NEXT_PUBLIC_SITE_URL=https://your-demo.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-demo.vercel.app

# ==== Feature Flags ====
FEATURE_HTS_SUGGESTIONS=true
NEXT_PUBLIC_FEATURE_HTS_SUGGESTIONS=true
NEXT_PUBLIC_FEATURE_DISABLE_REVIEW_RATES=true
NEXT_PUBLIC_HIDE_REVIEW_RATE_UI=true
NEXT_PUBLIC_ENABLE_SERVICE_STEP=true
SIMULATE_PAYMENT=true
PDF_BUILDER=token
PREVIEW_MODE=inline-pdf
USE_PDF_LIB=1
JOBS_BACKEND=memory
PAYMENTS_BACKEND=memory
SUCCESS_GATE_ENFORCE=true

# ==== デモログイン補助ボタン ====
NEXT_PUBLIC_DEMO_USER_EMAIL=demo-user@fql-demo.example.com
NEXT_PUBLIC_DEMO_USER_PASSWORD=DemoUser2026!
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo-admin@fql-demo.example.com
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=DemoAdmin2026!

# ==== 管理者メール（デモ用アカウント） ====
ADMIN_EMAILS=demo-admin@fql-demo.example.com

# ==== 安全装置 ====
MAX_RPM=20
KILL_SWITCH=false
PUBLIC_QUOTES_ORG_ID=<your-org-id>

# ============================================================
# ⚠️ 以下は Vercel に設定しないこと（デモ不要 or セキュリティリスク）
# ============================================================
# GITHUB_TOKEN          — 不要
# CURSOR_API_KEY        — 不要
# OPENAI_API_KEY_OPS    — 不要
# E2E_EMAIL / E2E_PASSWORD — 不要
# ADMIN_PASSWORD        — 不要（Supabase Auth で管理）
# HOOKDECK_API_KEY      — 不要（Webhook未使用）
# E2E_TEST_MODE         — 不要
# NEXT_PUBLIC_TEST_FORCE_ANCHORS — 不要
