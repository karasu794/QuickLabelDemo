{
  "name": "quicklabel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "set -euo pipefail; node -v; pnpm -v; echo 'Check env'; node scripts/check-env.js; pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ci": "next lint --max-warnings 0",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "typegen": "node scripts/typegen.mjs",
    "test:watch": "jest --watch",
    "postinstall": "node ./scripts/download-chromium.js"
  },
  "dependencies": {
